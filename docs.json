{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Finverse Documentations",
  "colors": {
    "primary": "#009FFF",
    "light": "#67CFFF",
    "dark": "#004E7D"
  },
  "favicon": "/images/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Finverse API - Docs",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "introduction"
            ]
          },
          {
            "group": "Authentication",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "POST /auth/customer/token"
            ]
          },
          {
            "group": "Data",
            "pages": [
              "data-api"
            ]
          },
          {
            "group": "Payments",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "payment-api",
              {
                "group": "Payment Links",
                "pages": [
                  "create-new-payment-link",
                  "POST /payment_links",
                  "GET /payment_links/{payment_link_id}"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/images/logo.svg",
    "dark": "/images/logo.svg"
  },
  "navbar": {
    "secondary": {
      "type": "button",
      "label": "Support",
      "href": "https://support.finverse.com"
    },
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.finverse.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/finversetech",
      "linkedin": "https://www.linkedin.com/company/finverse"
    }
  }
}
